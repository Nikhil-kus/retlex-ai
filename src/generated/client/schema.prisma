generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Shop {
  id        String    @id @default(cuid())
  name      String
  mobile    String
  address   String?
  qrCodeId  String    @unique
  products  Product[]
  bills     Bill[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id           String     @id @default(cuid())
  name         String
  localName    String?
  barcode      String?
  sellingPrice Float
  costPrice    Float
  unit         String // e.g. "kg", "pkt", "pc"
  imageUrl     String?
  category     String?
  shopId       String
  shop         Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  billItems    BillItem[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Bill {
  id            String     @id @default(cuid())
  billNumber    String     @unique
  date          DateTime   @default(now())
  customerName  String?
  customerPhone String?
  totalAmount   Float
  profit        Float
  status        String     @default("UNPAID") // "PAID" or "UNPAID"
  paymentMethod String? // "CASH", "UPI", etc.
  notes         String?
  shopId        String
  shop          Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  items         BillItem[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model BillItem {
  id           String   @id @default(cuid())
  billId       String
  bill         Bill     @relation(fields: [billId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  name         String
  quantity     Float
  unit         String
  sellingPrice Float
  costPrice    Float
  total        Float
}
